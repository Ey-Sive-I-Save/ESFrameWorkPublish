        1. \u4F7F\u7528 public static partial class ESDesignUtility 2. \u5728\u5185\u90E8\u521B\u5EFA
        public static class YourToolName 3. \u6DFB\u52A0\u5B8C\u6574\u7684 XML \u6CE8\u91CA\u6587\u6863
        4. \u786E\u4FDD\u65B9\u6CD5\u5177\u6709\u660E\u786E\u7684\u529F\u80FD\u548C\u9519\u8BEF\u5904\u7406
