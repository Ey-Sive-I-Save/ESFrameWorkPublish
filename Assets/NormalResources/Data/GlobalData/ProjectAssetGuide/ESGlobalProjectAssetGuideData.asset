        summary\uFF0C\u804C\u8D23\u7531\u58F0\u660E\u3001\u8DEF\u5F84\u548C\u5173\u952E\u65B9\u6CD5\u63A8\u65AD\u3002\n\u6E90\u7801\u7279\u5F81\uFF1ASerializable
