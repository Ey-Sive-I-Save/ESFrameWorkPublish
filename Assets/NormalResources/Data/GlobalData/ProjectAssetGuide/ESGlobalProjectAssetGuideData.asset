    - Name: readMe
      Entry: 1
      Data: "\u7236\u6A21\u5757\uFF1AObsolete / \u5E9F\u5F03\u7CFB\u7EDF\u5F52\u6863\n\u811A\u672C\uFF1AAStarPathfinding.cs\n\u4E3B\u58F0\u660E\uFF1Aclass
