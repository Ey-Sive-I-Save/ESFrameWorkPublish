        <see cref=\"AvatarTarget\"/> \u679A\u4E3E\u63D0\u4F9B Odin Inspector \u4E2D\u6587\u4E0B\u62C9\u9009\u9879\u3002
        \u5728\u4EFB\u610F\u5B57\u6BB5\u4E0A\u6DFB\u52A0 <c>[ValueDropdown(\"@ES.AvatarTargetDropdown.Options\")]</c>
