  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7f2d6d7f6aa04e3489af9de6f3f2d001, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "\u97F3\u6548\u5C42 Audio"
  summary: "\u89D2\u8272\u811A\u6B65\u3001\u6280\u80FD\u3001\u6B66\u5668\u7B49\u97F3\u6548\u6E90\u6216\u97F3\u6548\u6302\u70B9\u3002"
  readMe: "\u804C\u8D23\uFF1A\u7BA1\u7406\u89D2\u8272 AudioSource \u6216\u97F3\u6548\u51FA\u751F\u70B9\u3002\n\u9700\u8981\u811A\u672C\uFF1A\u53EF\u9009\u97F3\u6548\u64AD\u653E\u5668\u3001\u6280\u80FD\u97F3\u9891\u8F68\u9053\u8FD0\u884C\u65F6\u3002\n\u5173\u952E\u8BBE\u7F6E\uFF1A\u957F\u97F3\u6548\u4E0D\u5E94\u88AB\u5E8F\u5217\u7ED3\u675F\u5F3A\u884C\u621B\u7136\u800C\u6B62\uFF0C\u9664\u975E\u914D\u7F6E\u8981\u6C42\u3002\n\u7981\u6B62\u4E8B\u9879\uFF1A\u4E0D\u8981\u5728\u6BCF\u4E2A\u6280\u80FD
    Clip \u91CC\u65E0\u9650\u521B\u5EFA AudioSource \u4E0D\u56DE\u6536\u3002"
  requiredItems: []
  notes:
  - "\u97F3\u6548\u751F\u547D\u5468\u671F\u8981\u548C\u6280\u80FD/\u72B6\u6001\u9000\u51FA\u7B56\u7565\u5206\u5F00\u8003\u8651\u3002"
  ownerSystem: ES Stand / Character Prefab Guide
  lastUpdated: 2026-07-16
--- !u!114 &900101600
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 900100600}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7f2d6d7f6aa04e3489af9de6f3f2d001, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "\u76F8\u673A\u53C2\u8003\u70B9\u5C42"
  summary: "\u8FD9\u91CC\u53EA\u653E\u76F8\u673A Follow/Aim \u53C2\u8003\u70B9\uFF0C\u4E0D\u653E
    Main Camera \u672C\u4F53\u3002"
  readMe: "\u804C\u8D23\uFF1A\u63D0\u4F9B\u573A\u666F\u76F8\u673A\u7CFB\u7EDF\u8DDF\u968F\u548C\u7784\u51C6\u7684\u76EE\u6807
    Transform\u3002\n\u9700\u8981\u811A\u672C\uFF1A\u901A\u5E38\u4E0D\u9700\u8981\u811A\u672C\uFF0C\u7531
    Cinemachine \u6216\u76F8\u673A\u6A21\u5757\u5F15\u7528\u3002\n\u5173\u952E\u8BBE\u7F6E\uFF1AMain
    Camera / CinemachineCamera \u5E94\u653E\u5728\u573A\u666F\u76F8\u673A\u7CFB\u7EDF\u91CC\u3002\n\u7981\u6B62\u4E8B\u9879\uFF1A\u4E0D\u8981\u628A
    Main Camera \u4F5C\u4E3A\u73A9\u5BB6 Prefab \u5B50\u7269\u4F53\u957F\u671F\u7ED1\u5B9A\u3002"
  requiredItems:
  - CameraPivot
  - AimPivot
  notes:
  - "\u73A9\u5BB6\u63D0\u4F9B\u76EE\u6807\u70B9\uFF0C\u76F8\u673A\u7CFB\u7EDF\u8D1F\u8D23\u62CD\u3002"
  ownerSystem: ES Stand / Character Prefab Guide
  lastUpdated: 2026-07-16
