--- !u!114 &900100002
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 900100000}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7f2d6d7f6aa04e3489af9de6f3f2d001, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "\u73A9\u5BB6\u89D2\u8272\u5DE5\u4E1A\u7EA7\u5C42\u7EA7\u6A21\u677F"
  summary: "\u7528\u4E8E\u8BF4\u660E\u73A9\u5BB6\u89D2\u8272 Prefab \u7684\u63A8\u8350\u5C42\u7EA7\uFF1A\u903B\u8F91\u3001\u6A21\u578B\u3001IK/\u6302\u70B9\u3001\u88C5\u5907\u3001\u7279\u6548\u3001\u97F3\u6548\u3001\u76F8\u673A\u53C2\u8003\u70B9\u5206\u79BB\u3002"
  readMe: "\u8FD9\u4E2A\u7EC4\u4EF6\u53EA\u662F\u4E00\u5757 ReadMe \u8BF4\u660E\u724C\uFF0C\u4E0D\u53C2\u4E0E\u8FD0\u884C\u65F6\u903B\u8F91\u3002\n\n\u73A9\u5BB6\u89D2\u8272\u5E94\u6709\u4E00\u4E2A\u603B\u6839\uFF0C\u573A\u666F\u4E2D\u79FB\u52A8\u3001\u751F\u6210\u3001\u9500\u6BC1\u7684\u5355\u4F4D\u662F\u8FD9\u4E2A\u603B\u6839\u3002\n\u8FD0\u884C\u65F6\u903B\u8F91\u4E0E\u78B0\u649E\u8D1F\u8D23
    Entity\u3001KCC\u3001Capsule\u3001StateMachine\u3001InputBridge \u7B49\u63A7\u5236\u80FD\u529B\u3002\n\u6A21\u578B\u8868\u73B0\u53EA\u653E\u6A21\u578B\u3001\u9AA8\u9ABC\u548C\u7F51\u683C\uFF0C\u5C3D\u91CF\u4E0D\u8981\u628A\u4E1A\u52A1\u811A\u672C\u76F4\u63A5\u585E\u8FDB\u6A21\u578B\u9AA8\u9ABC\u5C42\u7EA7\u3002\n\u52A8\u753B\u8F85\u52A9\u8D1F\u8D23
    IK \u76EE\u6807\u548C\u6302\u70B9\uFF0C\u4F8B\u5982 AimTarget\u3001LookAtTarget\u3001\u5DE6\u53F3\u624B\u6302\u70B9\u3001\u80CC\u90E8\u6302\u70B9\u3002\n\u88C5\u5907\u8D1F\u8D23\u5F53\u524D\u6B66\u5668\u548C\u5907\u7528\u69FD\u4F4D\uFF0C\u6B66\u5668\u7CFB\u7EDF\u518D\u51B3\u5B9A\u6302\u5230\u54EA\u4E2A\u6302\u70B9\u3002\n\u76F8\u673A\u53C2\u8003\u70B9\u4E0D\u662F
    Main Camera \u672C\u4F53\u3002Main Camera / Cinemachine \u5EFA\u8BAE\u653E\u5728\u573A\u666F\u76F8\u673A\u7CFB\u7EDF\u91CC\uFF0C\u53EA\u5F15\u7528\u73A9\u5BB6\u8EAB\u4E0A\u7684
    Follow/Aim \u70B9\u3002"
  requiredItems:
  - "\u603B\u6839\uFF1A\u4EE3\u8868\u5B8C\u6574\u89D2\u8272\u5B9E\u4F8B\uFF0C\u662F\u751F\u6210\u3001\u9500\u6BC1\u3001\u4F20\u9001\u3001\u6574\u4F53\u79FB\u52A8\u7684\u5BF9\u8C61\u3002"
  - "\u8FD0\u884C\u65F6\u903B\u8F91\u4E0E\u78B0\u649E\uFF1A\u653E Entity\u3001KCC\u3001Capsule\u3001StateMachine\u3001InputBridge\u3002"
  - "\u6A21\u578B\u8868\u73B0\uFF1A\u653E\u6A21\u578B\u5B9E\u4F8B\u3001\u9AA8\u9ABC\u6839\u3001\u7F51\u683C\uFF0C\u4E0D\u627F\u62C5\u4E1A\u52A1\u903B\u8F91\u3002"
  - "\u52A8\u753B\u8F85\u52A9\uFF1A\u653E IK \u76EE\u6807\u548C\u6302\u70B9\uFF0C\u4F9B\u52A8\u753B\u3001\u6B66\u5668\u3001\u6280\u80FD\u3001MatchTarget
    \u4F7F\u7528\u3002"
  - "\u76F8\u673A\u53C2\u8003\u70B9\uFF1A\u53EA\u653E Follow/Aim \u7B49\u76EE\u6807\u70B9\uFF0C\u4E0D\u653E
    Main Camera \u672C\u4F53\u3002"
  notes:
  - "\u4E0D\u8981\u628A Main Camera \u76F4\u63A5\u653E\u8FDB\u73A9\u5BB6 Prefab\uFF0C\u73A9\u5BB6\u53EA\u63D0\u4F9B\u76F8\u673A\u53C2\u8003\u70B9\u3002"
  - "\u4E0D\u8981\u76F4\u63A5\u628A\u4E1A\u52A1\u903B\u8F91\u6302\u5728\u5BFC\u5165\u6A21\u578B\u7684\u9AA8\u9ABC\u6839\u4E0A\uFF0C\u6362\u6A21\u578B\u65F6\u4F1A\u5F88\u75DB\u3002"
  - "KCC \u89D2\u8272\u5982\u679C\u9700\u8981 Rigidbody\uFF0C\u901A\u5E38\u5E94\u4F7F\u7528
    Kinematic\uFF0C\u907F\u514D\u7269\u7406\u7CFB\u7EDF\u81EA\u52A8\u63A8\u52A8\u4E3B\u89D2\u3002"
  - "\u6B66\u5668\u3001IK\u3001VFX\u3001Audio \u5C3D\u91CF\u8D70\u4E13\u7528\u5206\u7EC4\uFF0C\u907F\u514D\u6563\u843D\u5728\u9AA8\u9ABC\u548C\u573A\u666F\u6839\u4E0B\u3002"
  ownerSystem: ES Stand / Character Prefab Guide
  lastUpdated: 2026-07-16
