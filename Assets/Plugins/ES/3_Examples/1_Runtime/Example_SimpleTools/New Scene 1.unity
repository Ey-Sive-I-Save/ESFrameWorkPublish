  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7f2d6d7f6aa04e3489af9de6f3f2d001, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "\u8FD0\u884C\u65F6\u903B\u8F91\u4E0E\u78B0\u649E"
  summary: "\u89D2\u8272\u63A7\u5236\u3001\u78B0\u649E\u3001\u72B6\u6001\u673A\u548C\u8F93\u5165\u6865\u63A5\u7684\u5F52\u5C5E\u5C42\u3002"
  readMe: "\u804C\u8D23\uFF1A\u627F\u8F7D\u73A9\u5BB6\u8FD0\u884C\u65F6\u63A7\u5236\u80FD\u529B\uFF0C\u4E0D\u653E\u6A21\u578B\u7F51\u683C\u548C\u8868\u73B0\u8D44\u6E90\u3002\n\u9700\u8981\u811A\u672C\uFF1AEntity\u3001KinematicCharacterMotor\u3001CapsuleCollider/\u80F6\u56CA\u5F15\u7528\u3001EntityStateDomain\u3001\u8F93\u5165\u6865\u63A5\u6A21\u5757\u3002\n\u5173\u952E\u8BBE\u7F6E\uFF1A\u8BE5\u5C42\u5E94\u8DDF\u968F\u73A9\u5BB6\u603B\u6839\uFF0C\u5750\u6807\u901A\u5E38\u4FDD\u6301\u672C\u5730\u96F6\u4F4D\uFF1B\u78B0\u649E\u9AD8\u5EA6\u3001\u534A\u5F84\u3001KCC
    \u7A33\u5B9A\u5730\u9762\u5C42\u5728\u8FD9\u91CC\u7EDF\u4E00\u7EF4\u62A4\u3002\n\u7981\u6B62\u4E8B\u9879\uFF1A\u4E0D\u8981\u628A
    SkinnedMeshRenderer\u3001\u6B66\u5668\u6A21\u578B\u3001VFX \u5B9E\u4F8B\u957F\u671F\u585E\u8FDB\u8FD9\u91CC\u3002"
  requiredItems:
  - Entity
  - KCCMotor
  - Capsule
  - StateMachine
  - InputBridge
  notes:
  - "\u8FD9\u662F\u8FD0\u884C\u65F6\u63A7\u5236\u5C42\uFF0C\u4E0D\u662F\u8868\u73B0\u5C42\u3002"
  ownerSystem: ES Stand / Character Prefab Guide
  lastUpdated: 2026-07-16
