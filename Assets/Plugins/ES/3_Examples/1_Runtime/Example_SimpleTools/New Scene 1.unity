  readMe: "\u804C\u8D23\uFF1A\u627F\u8F7D\u6280\u80FD\u4E34\u65F6\u7269\u3001\u9884\u89C8\u6B8B\u7559\u6E05\u7406\u5BF9\u8C61\u3001\u8FD0\u884C\u65F6\u751F\u6210\u6302\u70B9\u3001\u4E34\u65F6
    VFX/Audio \u5BB9\u5668\u3002\n\u9700\u8981\u811A\u672C\uFF1A\u53EF\u9009 RuntimeGeneratedScope
