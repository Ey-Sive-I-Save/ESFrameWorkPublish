  summary: "\u89D2\u8272\u5E38\u9A7B\u7279\u6548\u3001\u4E34\u65F6\u7279\u6548\u51FA\u751F\u70B9\u548C\u7279\u6548\u6C60\u6302\u8F7D\u4F4D\u7F6E\u3002"
  readMe: "\u804C\u8D23\uFF1A\u7BA1\u7406\u89D2\u8272\u76F8\u5173 VFX \u5BB9\u5668\u3002\n\u9700\u8981\u811A\u672C\uFF1A\u53EF\u9009
    VFX \u7BA1\u7406\u5668\u3001\u5BF9\u8C61\u6C60\u6302\u70B9\u3002\n\u5173\u952E\u8BBE\u7F6E\uFF1A\u6280\u80FD\u7279\u6548\u5E94\u80FD\u5728\u72B6\u6001\u9000\u51FA/\u5BF9\u8C61\u9500\u6BC1\u65F6\u7EDF\u4E00\u56DE\u6536\u3002\n\u7981\u6B62\u4E8B\u9879\uFF1A\u4E0D\u8981\u8BA9\u9884\u89C8\u6B8B\u7559\u7279\u6548\u7559\u5728\u771F\u5B9E\u573A\u666F\u3002"
  requiredItems: []
  notes:
  - "\u6280\u80FD\u7F16\u8F91\u5668\u9884\u89C8\u8D44\u6E90\u4E5F\u5E94\u6709\u6E05\u7406\u7B56\u7565\u3002"
  ownerSystem: ES Stand / Character Prefab Guide
  lastUpdated: 2026-07-16
