    VFX/Audio \u5BB9\u5668\u3002\n\u9700\u8981\u811A\u672C\uFF1A\u53EF\u9009 RuntimeGeneratedScope
    \u6216\u5BF9\u8C61\u6C60\u5F52\u8FD8\u5668\u3002\n\u5173\u952E\u8BBE\u7F6E\uFF1A\u89D2\u8272\u9500\u6BC1\u3001\u9000\u51FA
    PlayMode\u3001\u5207\u573A\u666F\u3001\u6280\u80FD\u7ED3\u675F\u65F6\u5FC5\u987B\u6E05\u7406\u3002\n\u7981\u6B62\u4E8B\u9879\uFF1A\u4E0D\u8981\u628A\u624B\u5DE5\u914D\u7F6E\u7684\u6838\u5FC3\u6302\u70B9\u653E\u8FDB\u8FD9\u91CC\u3002"
  requiredItems:
  - "\u7EDF\u4E00\u6E05\u7406\u7B56\u7565"
  notes:
  - "\u8FD9\u4E2A\u8282\u70B9\u662F\u9632\u6B62\u9884\u89C8\u6B8B\u7559\u548C\u8FD0\u884C\u65F6\u6CC4\u6F0F\u7684\u4FDD\u9669\u533A\u3002"
